// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  password      String
  role          String   @default("VERIFIER")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  documents     Document[] @relation("DocumentCreator")
  verifications Verification[] @relation("VerificationReviewer")
}

model Document {
  id              String   @id @default(cuid())
  documentNumber  String   @unique
  title           String
  description     String?
  type            String
  amount          Float
  date            DateTime
  status          String   @default("PENDING")
  riskScore       Float?
  riskLevel       String?
  notes           String?
  filePath        String?
  createdBy       String
  creator         User     @relation("DocumentCreator", fields: [createdBy], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  verifications   Verification[]
  checklistItems  ChecklistItem[]

  @@index([type])
  @@index([status])
  @@index([createdBy])
}

model Verification {
  id              String   @id @default(cuid())
  documentId      String
  document        Document @relation(fields: [documentId], references: [id])
  reviewerId      String
  reviewer        User     @relation("VerificationReviewer", fields: [reviewerId], references: [id])
  status          String
  comments        String?
  findings        String?
  reviewedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([documentId])
  @@index([reviewerId])
}

model ChecklistItem {
  id              String   @id @default(cuid())
  documentId      String
  document        Document @relation(fields: [documentId], references: [id])
  label           String
  isChecked       Boolean  @default(false)
  isRequired      Boolean  @default(true)
  category        String?
  createdAt       DateTime @default(now())

  @@index([documentId])
}
